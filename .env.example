# ============================================================
# CONFIGURACIÓN — Copia este archivo a .env y rellena los valores
# ============================================================

# REQUERIDO — API key de Gemini (obtener gratis en https://aistudio.google.com/app/apikey)
# Cualquiera de las dos funciona; si están las dos, el código prioriza GOOGLE_API_KEY.
GOOGLE_API_KEY=
GEMINI_API_KEY=

# ============================================================
# OPCIONAL — Solo si quieres correr el scraping de la Prueba 1
# La app desplegada NO necesita esto.
# ============================================================

CHROME_BINARY=/usr/bin/google-chrome
CHROME_PROFILE_PATH=/home/brian/.config/google-chrome
CHROME_DEBUG_PORT=9222
SCRAPE_START_HOUR=12
SCRAPE_END_HOUR=20
